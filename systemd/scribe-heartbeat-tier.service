[Unit]
Description=Scribe heartbeat (tier-aware: T0/T1/T2/T3 cadence; mirrors forge-heartbeat-tier per PROTOCOL.md v2.0)
Documentation=https://github.com/laulpogan (cross-project pattern; canonical impl in paul-thinkpiece-pipeline/src/forge/coordination/heartbeat.py)

[Service]
Type=oneshot
WorkingDirectory=/home/admin/Source/our-lady-book-pipeline
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/home/admin/paul-thinkpiece-pipeline/src
ExecStart=/usr/bin/python3 -m forge.coordination.heartbeat \
    --state-file /home/admin/Source/our-lady-book-pipeline/_coordination/scribe_pipeline_state.json \
    --dead-drop /home/admin/paul-thinkpiece-pipeline/_coordination/novel_to_voice.jsonl \
    --tier-spec /home/admin/paul-thinkpiece-pipeline/_coordination/tiers.json
StandardOutput=journal
StandardError=journal
